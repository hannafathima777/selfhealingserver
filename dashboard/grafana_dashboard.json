{
  "title": "Self-Healing Server Dashboard",
  "uid": "self-healing-v1",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "target": "cpu"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "RAM Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "B",
          "target": "ram"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Disk Usage (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Health Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "healthy": { "color": "green", "index": 0, "text": "✅ Healthy" } }, "type": "value" },
            { "options": { "container_down": { "color": "red", "index": 1, "text": "❌ Container Down" } }, "type": "value" },
            { "options": { "app_unresponsive": { "color": "orange", "index": 2, "text": "⚠️ App Unresponsive" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Anomaly Events",
      "type": "logs",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s"
}